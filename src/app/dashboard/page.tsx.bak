"use client";

import { motion } from "motion/react";
import { RiMoneyDollarCircleLine, RiPercentLine, RiCalendarLine, RiTeamLine } from "react-icons/ri";
import { AreaChart, Area, XAxis, YAxis, CartesianGrid, Tooltip, ResponsiveContainer } from "recharts";

const chartData = [
  { day: "Mon", bookings: 12 },
  { day: "Tue", bookings: 19 },
  { day: "Wed", bookings: 15 },
  { day: "Thu", bookings: 28 },
  { day: "Fri", bookings: 35 },
  { day: "Sat", bookings: 42 },
  { day: "Sun", bookings: 38 },
];

const recentReservations = [
  {
    id: 1,
    customer: "Sarah Johnson",
    type: "Table",
    date: "May 16-17, 2026",
    guests: 6,
    status: "Confirmed",
  },
  {
    id: 2,
    customer: "Michael Brown",
    type: "Room",
    date: "May 18-20, 2026",
    guests: 2,
    status: "Pending",
  },
  {
    id: 3,
    customer: "Emma Davis",
    type: "Event",
    date: "May 25, 2026",
    guests: 150,
    status: "Confirmed",
  },
];

const stats = [
  {
    icon: RiMoneyDollarCircleLine,
    label: "Monthly Revenue",
    value: "2.4M",
    unit: "XAF",
    change: "+23.1%",
    positive: true,
  },
  {
    icon: RiPercentLine,
    label: "Occupancy Rate",
    value: "87%",
    change: "+8.2%",
    positive: true,
  },
  {
    icon: RiCalendarLine,
    label: "Total Bookings",
    value: "1,247",
    change: "+12.5%",
    positive: true,
  },
  {
    icon: RiTeamLine,
    label: "Total Guests",
    value: "4,892",
    change: "+15.3%",
    positive: true,
  },
];

export default function DashboardOverview() {
  return (
    <div className="space-y-8">
      {/* Header */}
      <motion.div
        initial={{ opacity: 0, y: 20 }}
        animate={{ opacity: 1, y: 0 }}
        transition={{ duration: 0.6 }}
      >
        <h1 className="text-4xl font-bold mb-2">Welcome back, John!</h1>
        <p className="text-[var(--muted-foreground)]">
          Here's what's happening with your business today
        </p>
      </motion.div>

      {/* Stats Cards */}
      <div className="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        {stats.map((stat, index) => {
          const Icon = stat.icon;

          return (
            <motion.div
              key={stat.label}
              initial={{ opacity: 0, y: 20 }}
              animate={{ opacity: 1, y: 0 }}
              transition={{ delay: index * 0.1, duration: 0.6 }}
              className="card"
            >
              <div className="flex justify-between items-start mb-4">
                <div className="w-12 h-12 bg-[var(--primary)]/10 rounded-2xl flex items-center justify-center">
                  <Icon className="w-6 h-6 text-[var(--primary)]" />
                </div>
                <span className="text-green-400 bg-green-400/10 px-2 py-1 rounded-xl text-xs font-medium">
                  {stat.change}
                </span>
              </div>
              <h3 className="text-2xl font-bold mb-1">{stat.value}</h3>
              {stat.unit && <span className="text-[var(--muted-foreground)] text-xs">{stat.unit}</span>}
              <p className="text-[var(--muted-foreground)] text-sm">{stat.label}</p>
            </motion.div>
          );
        })}
      </div>

      {/* Charts Section */}
      <motion.div
        initial={{ opacity: 0, y: 20 }}
        animate={{ opacity: 1, y: 0 }}
        transition={{ delay: 0.4, duration: 0.6 }}
        className="card p-8"
      >
        <h2 className="text-2xl font-bold mb-6">Booking Trends</h2>
        <ResponsiveContainer width="100%" height={300}>
          <AreaChart data={chartData}>
            <defs>
              <linearGradient id="colorBookingsGold" x1="0" y1="0" x2="0" y2="1">
                <stop offset="5%" stopColor="var(--primary)" stopOpacity={0.3} />
                <stop offset="95%" stopColor="var(--primary)" stopOpacity={0} />
              </linearGradient>
            </defs>
            <CartesianGrid strokeDasharray="3 3" stroke="var(--border)" />
            <XAxis dataKey="day" stroke="var(--muted-foreground)" />
            <YAxis stroke="var(--muted-foreground)" />
            <Tooltip
              contentStyle={{
                backgroundColor: "var(--card)",
                border: "1px solid var(--border)",
              }}
            />
            <Area
              type="monotone"
              dataKey="bookings"
              stroke="var(--primary)"
              strokeWidth={2}
              fill="url(#colorBookingsGold)"
            />
          </AreaChart>
        </ResponsiveContainer>
      </motion.div>

      {/* Quick Actions */}
      <motion.div
        initial={{ opacity: 0, y: 20 }}
        animate={{ opacity: 1, y: 0 }}
        transition={{ delay: 0.5, duration: 0.6 }}
        className="grid grid-cols-1 md:grid-cols-4 gap-4"
      >
        <button className="btn-primary py-3">New Reservation</button>
        <button className="btn-secondary py-3">View Calendar</button>
        <button className="btn-secondary py-3">Update Listings</button>
        <button className="btn-secondary py-3">Send Message</button>
      </motion.div>

      {/* Recent Reservations */}
      <motion.div
        initial={{ opacity: 0, y: 20 }}
        animate={{ opacity: 1, y: 0 }}
        transition={{ delay: 0.6, duration: 0.6 }}
        className="card p-8"
      >
        <h2 className="text-2xl font-bold mb-6">Recent Reservations</h2>
        <div className="overflow-x-auto">
          <table className="w-full">
            <thead>
              <tr className="border-b border-[var(--border)]">
                <th className="text-left py-3 text-sm font-semibold text-[var(--muted-foreground)]">
                  Customer
                </th>
                <th className="text-left py-3 text-sm font-semibold text-[var(--muted-foreground)]">
                  Type
                </th>
                <th className="text-left py-3 text-sm font-semibold text-[var(--muted-foreground)]">
                  Date
                </th>
                <th className="text-left py-3 text-sm font-semibold text-[var(--muted-foreground)]">
                  Guests
                </th>
                <th className="text-left py-3 text-sm font-semibold text-[var(--muted-foreground)]">
                  Status
                </th>
              </tr>
            </thead>
            <tbody>
              {recentReservations.map((res) => (
                <tr key={res.id} className="border-b border-[var(--border)] hover:bg-[var(--secondary)] transition-colors">
                  <td className="py-4 font-medium">{res.customer}</td>
                  <td className="py-4 text-[var(--muted-foreground)]">{res.type}</td>
                  <td className="py-4 text-[var(--muted-foreground)]">{res.date}</td>
                  <td className="py-4 text-[var(--muted-foreground)]">{res.guests}</td>
                  <td className="py-4">
                    <span
                      className={`px-3 py-1 rounded-lg text-xs font-medium ${
                        res.status === "Confirmed"
                          ? "bg-green-500/10 text-green-400"
                          : "bg-yellow-500/10 text-yellow-400"
                      }`}
                    >
                      {res.status}
                    </span>
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </motion.div>
    </div>
  );
}
